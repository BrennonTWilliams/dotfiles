# ==============================================================================
# Directory Navigation Abbreviations
# ==============================================================================

# Zoxide directory jumping
abbr -S j='z'
abbr -S ji='zi'

# Parent directory shortcuts
abbr -S ..='cd ..'
abbr -S ...='cd ../..'
abbr -S ....='cd ../../..'
abbr -S .....='cd ../../../..'

# Directory tree views
abbr -S tredir='eza -T -D --git-ignore'
